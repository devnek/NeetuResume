# Ignore all files by default
*

# Allow directories
!*/

# Allow specific source and project files
!*.tex
!*.cls
!*.jpeg
!*.pdf
!*.docx
!*.py
!.gitignore
!GEMINI.md
!README.md

# Ignore macOS system files
.DS_Store
**/.DS_Store

# Re-ignore all LaTeX auxiliary and temporary build files (to be sure)
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fmt
*.fot
*.cb
*.cb2
.*.lb
*.dvi
*.xdv
*-converted-to.*
*.bbl
*.bcf
*.blg
*-blx.aux
*-blx.bib
*.run.xml
*.fdb_latexmk
*.synctex
*.synctex(busy)
*.synctex.gz
*.synctex.gz(busy)
*.pdfsync
latex.out/
*.idx
*.ilg
*.ind
*.maf
*.mlf
*.mlt
*.mtc[0-9]*
*.slf[0-9]*
*.slt[0-9]*
*.stc[0-9]*
_minted*
*.pyg
*.listing
*.dpth
*.md5
*.auxlock
